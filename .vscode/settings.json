{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "akari",
    "esbuild",
    "Fira",
    "Neue",
    "oxfmt",
    "oxlint",
    "pnpm",
    "Roboto",
    "Segoe",
    "Shuvi",
    "tsgo",
    "unrs",
    "VITE",
    "wakaba"
  ]
}
